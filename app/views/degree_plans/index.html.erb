<% content_for :title, "Plans — KTU ECE" %>

<div class="binary-plans-page">
  <header>
    <div>
      <p class="binary-eyebrow">Your study</p>
      <h1>Plans.</h1>
    </div>
    <%= link_to "New plan", new_degree_plan_path, class: "binary-btn" %>
  </header>

  <% if @plans.any? %>
    <ol class="binary-plans-list">
      <% @plans.each_with_index do |plan, i| %>
        <li>
          <span class="num"><%= format("%02d", i + 1) %></span>
          <%= link_to plan.title, plan, class: "name" %>
          <span class="meta">
            <%= plan.branch %> · <%= plan.scheme %> · <%= plan.plan_selections.count %> picks
          </span>
        </li>
      <% end %>
    </ol>
  <% else %>
    <p class="binary-lede" style="max-width: 60ch;">
      You haven't created any plans yet. A plan lets you pick your electives across
      the six elective slots and see the credit picture filled in.
      <%= link_to "Start one", new_degree_plan_path, class: "binary-link" %>.
    </p>
  <% end %>
</div>
