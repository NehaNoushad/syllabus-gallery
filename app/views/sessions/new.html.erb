<% content_for :title, "Sign in — KTU ECE" %>

<div class="binary-form-page">
  <p class="binary-eyebrow">Returning student</p>
  <h1>Sign in.</h1>

  <%= form_with url: session_url, class: "binary-form" do |form| %>
    <div class="binary-field">
      <label class="binary-label" for="email_address">Email</label>
      <%= form.email_field :email_address,
                           id: "email_address",
                           required: true,
                           autofocus: true,
                           autocomplete: "username",
                           value: params[:email_address],
                           class: "binary-input" %>
    </div>

    <div class="binary-field">
      <label class="binary-label" for="password">Password</label>
      <%= form.password_field :password,
                              id: "password",
                              required: true,
                              autocomplete: "current-password",
                              maxlength: 72,
                              class: "binary-input" %>
    </div>

    <div class="binary-form-actions">
      <%= form.submit "Sign in", class: "binary-btn" %>
      <%= link_to "Forgot password", new_password_path, class: "binary-link" %>
    </div>
  <% end %>

  <p class="binary-hint" style="margin-top: 40px;">
    No account yet? <%= link_to "Create one", sign_up_path, class: "binary-link" %>.
  </p>
</div>
