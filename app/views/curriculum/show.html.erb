<% content_for :title, "KTU ECE — Curriculum" %>

<%
  categories_with_credits = @total_credits_by_category.reject { |_, cr| cr.zero? }
  max_cat_credits = categories_with_credits.values.max || 1
%>

<!-- HERO -->
<section class="binary-hero">
  <div class="binary-hero-left">
    <p class="binary-eyebrow">KTU · B.Tech · 2019 Scheme</p>
    <h1 class="binary-display">The<br>curriculum</h1>
    <p class="binary-lede">
      The shape of an Electronics &amp; Computer Engineering degree, presented
      as it is intended to be read. Eight semesters. Sixty subjects. No commentary.
    </p>
    <%= link_to "Browse the catalog →", subjects_path, class: "backlink" %>
  </div>
  <div class="binary-hero-right">
    <p class="binary-eyebrow">Read the structure</p>
    <h1 class="binary-display">Every credit<br>accounted for</h1>
    <p class="binary-lede">
      Mathematics, science, core engineering, software, labs, electives, project.
      Ordered, sequential, deliberate.
    </p>
  </div>
</section>

<!-- CREDIBILITY -->
<section class="binary-credline">
  <span>APJ Abdul Kalam Technological University</span>
  <span>B.Tech Electronics &amp; Computer Engineering</span>
  <span>2019 Scheme</span>
  <span><%= @total_credits %> mandatory credits</span>
  <span>8 semesters</span>
</section>

<!-- 2 × 4 SEMESTER GRID — entire degree visible at a glance -->
<section class="binary-grid">
  <% @by_semester.each do |semester, subjects| %>
    <% sem_credits = subjects.sum(&:credits) %>
    <article class="binary-card">
      <header class="binary-card-head">
        <span class="binary-card-num"><%= format("%02d", semester) %> /</span>
        <h2 class="binary-card-title">Semester <%= semester %></h2>
        <span class="binary-card-credits"><%= sem_credits %> credits</span>
      </header>

      <ol class="binary-card-subjects">
        <% subjects.each_with_index do |s, i| %>
          <li>
            <span class="num"><%= format("%02d", i + 1) %></span>
            <span class="name">
              <% if s.code.present? && !s.code.include?("XXX") %><span class="code"><%= s.code %></span><% end %><%= s.name %>
            </span>
            <span class="cr"><%= s.credits.zero? ? "—" : "#{s.credits} cr" %></span>
          </li>
        <% end %>
      </ol>
    </article>
  <% end %>
</section>

<!-- BY CATEGORY OVERVIEW — the bottom summary, like v1 -->
<section class="binary-cat-overview inverted">
  <div class="binary-cat-inner">
    <header class="binary-semester-head">
      <span class="binary-sem-num">00 /</span>
      <h2 class="binary-sem-title">By category</h2>
      <span class="binary-sem-credits">Whole degree</span>
    </header>

    <ol class="binary-cat-table">
      <% categories_with_credits.sort_by { |_, cr| -cr }.each_with_index do |(cat, cr), i| %>
        <li>
          <span class="binary-cat-num"><%= format("%02d", i + 1) %></span>
          <span class="binary-cat-name"><%= Subject::CATEGORY_LABELS[cat] %></span>
          <span class="binary-cat-bar" style="width: <%= ((cr.to_f / max_cat_credits) * 100).round(1) %>%"></span>
          <span class="binary-cat-cr"><%= cr %> cr</span>
        </li>
      <% end %>
    </ol>
  </div>
</section>

<footer class="binary-foot">
  <span>End of curriculum</span>
  <span><%= @total_credits %> credits total</span>
</footer>
