<% content_for :title, "Reset password — KTU ECE" %>

<div class="binary-form-page">
  <p class="binary-eyebrow">Account recovery</p>
  <h1>Reset your password.</h1>

  <p class="binary-lede" style="margin-top: 16px;">
    Enter the email you signed up with. If it matches an account, we'll send
    instructions for setting a new password.
  </p>

  <%= form_with url: passwords_path, class: "binary-form" do |form| %>
    <div class="binary-field">
      <label class="binary-label" for="email_address">Email</label>
      <%= form.email_field :email_address,
                           id: "email_address",
                           required: true,
                           autofocus: true,
                           autocomplete: "username",
                           value: params[:email_address],
                           class: "binary-input" %>
    </div>

    <div class="binary-form-actions">
      <%= form.submit "Email reset instructions", class: "binary-btn" %>
      <%= link_to "Back to sign in", new_session_path, class: "binary-link" %>
    </div>
  <% end %>
</div>
