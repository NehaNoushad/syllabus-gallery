<% content_for :title, "KTU ECE Subjects" %>

<div class="max-w-5xl mx-auto px-4 py-8">
  <header class="mb-6">
    <h1 class="text-2xl font-semibold tracking-tight">KTU B.Tech ECE — Subjects</h1>
    <p class="text-sm text-gray-500">
      Electronics &amp; Computer Engineering · 2019 Scheme ·
      <%= @subjects_by_semester.values.flatten.sum(&:credits) %> credits total
    </p>
  </header>

  <% @subjects_by_semester.each do |semester, subjects| %>
    <% sem_credits = subjects.sum(&:credits) %>
    <section class="mb-8 border border-gray-200 rounded-lg overflow-hidden">
      <div class="flex justify-between items-baseline px-4 py-2 bg-gray-50 border-b border-gray-200">
        <h2 class="text-sm font-semibold">Semester <%= semester %></h2>
        <span class="text-xs text-gray-500"><%= sem_credits %> credits</span>
      </div>

      <ul class="divide-y divide-gray-100">
        <% subjects.each do |s| %>
          <li class="flex items-center justify-between px-4 py-2 text-sm">
            <div class="flex items-center gap-3">
              <span class="inline-block w-2 h-2 rounded-sm bg-<%= s.category %>"
                    style="<%= "background-color: #{category_color(s.category)};" %>"></span>
              <span><%= s.name %></span>
              <% if s.elective_group.present? %>
                <span class="text-xs text-gray-400">(<%= s.elective_group %>)</span>
              <% end %>
            </div>
            <div class="flex items-center gap-3 text-xs text-gray-500">
              <span><%= s.category_label %></span>
              <span class="font-mono w-10 text-right">
                <%= s.credits.zero? ? "—" : "#{s.credits} cr" %>
              </span>
            </div>
          </li>
        <% end %>
      </ul>
    </section>
  <% end %>
</div>
