<% content_for :title, "Syllabus directory" %>

<!-- DASHBOARD HERO -->
<section class="binary-hero">
  <div class="binary-hero-left">
    <p class="binary-eyebrow">Syllabus directory</p>
    <h1 class="binary-display">Find your<br>syllabus.</h1>
    <p class="binary-lede">
      A directory of university curricula, presented as serious documents —
      not marketing brochures. Pick a program. Read it like a textbook.
    </p>
    <%= link_to "Browse syllabuses →", programs_path, class: "binary-btn", style: "margin-top: 10px;" %>
  </div>
  <div class="binary-hero-right has-image"
       style="--bg: url('https://images.unsplash.com/photo-1503676260728-1c00da094a0b?auto=format&fit=crop&w=1600&q=80')">
    <p class="binary-eyebrow">No ornament</p>
    <h1 class="binary-display">Numbered.<br>Ordered.<br>Complete.</h1>
    <p class="binary-lede">
      Every credit accounted for. Every elective named. No commentary on whether
      a subject is "interesting" — only the structure as it is intended to be taught.
    </p>
    <p class="binary-photo-credit">Photo · Susan Yin / Unsplash</p>
  </div>
</section>

<!-- HOW IT WORKS — credibility-strip style -->
<section class="binary-credline">
  <span>1 — Pick a program</span>
  <span>2 — Read the curriculum</span>
  <span>3 — Save your elective plan</span>
</section>

<!-- AVAILABLE PROGRAMS preview -->
<section class="binary-cat-overview">
  <div class="binary-cat-inner">
    <header class="binary-semester-head">
      <span class="binary-sem-num">01 /</span>
      <h2 class="binary-sem-title">Available syllabuses</h2>
      <span class="binary-sem-credits"><%= @programs.size %> in directory</span>
    </header>

    <ol class="binary-plans-list" style="margin: 0;">
      <% @programs.each_with_index do |program, i| %>
        <li>
          <span class="num"><%= format("%02d", i + 1) %></span>
          <%= link_to program.title, program_path(program.slug), class: "name" %>
          <span class="meta">
            <%= program.scheme %> Scheme · <%= program.total_credits %> cr · <%= program.total_semesters %> semesters
          </span>
        </li>
      <% end %>
    </ol>

    <p class="binary-hint" style="margin-top: 24px;">
      More programs will appear here as their syllabus data is added.
      <%= link_to "Open the full directory →", programs_path, class: "binary-link", style: "margin-left: 8px;" %>
    </p>
  </div>
</section>

<!-- ANNOUNCEMENTS — admin posts, everyone reads -->
<section class="binary-cat-overview inverted" id="announcements">
  <div class="binary-cat-inner">
    <header class="binary-semester-head">
      <span class="binary-sem-num">02 /</span>
      <h2 class="binary-sem-title">Announcements</h2>
      <span class="binary-sem-credits"><%= @announcements.size %> note<%= "s" unless @announcements.size == 1 %></span>
    </header>

    <% if Current.user&.admin? %>
      <%= form_with model: @new_announcement, class: "binary-announce-form" do |f| %>
        <%= f.text_field :title, placeholder: "Title (optional)", class: "binary-input", maxlength: 120 %>
        <%= f.text_area  :content, placeholder: "What's new?", class: "binary-input binary-textarea", rows: 3, maxlength: 1000, required: true %>
        <%= f.submit "Post announcement", class: "binary-btn binary-btn-inverted" %>
      <% end %>
    <% end %>

    <% if @announcements.any? %>
      <ol class="binary-announce-list">
        <% @announcements.each_with_index do |a, i| %>
          <li>
            <span class="num"><%= format("%02d", i + 1) %></span>
            <div class="body">
              <div class="head">
                <% if a.title.present? %><span class="title"><%= a.title %></span><% end %>
                <span class="time"><%= a.created_at.strftime("%Y-%m-%d · %H:%M") %></span>
              </div>
              <div class="content"><%= simple_format(a.content) %></div>
            </div>
            <% if Current.user&.admin? %>
              <%= button_to "Remove",
                            announcement_path(a),
                            method: :delete,
                            form: { data: { turbo_confirm: "Delete this announcement?" } },
                            class: "binary-link binary-announce-remove" %>
            <% end %>
          </li>
        <% end %>
      </ol>
    <% else %>
      <p class="binary-empty" style="border: 0; padding: 32px 0; text-align: left;">
        No announcements yet.<% if Current.user&.admin? %> Post the first one above.<% end %>
      </p>
    <% end %>
  </div>
</section>

<footer class="binary-foot">
  <span>End of dashboard</span>
  <span><%= @programs.size %> program<%= "s" unless @programs.size == 1 %> available</span>
</footer>
